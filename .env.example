# ── Site URL ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sadikstudio.in

# Comma-separated list of additional origins allowed to make state-changing
# API requests (CSRF defense). Useful for staging domains.
# Production tip: include EVERY domain that runs the same Next app.
ALLOWED_ORIGINS=

# ── Supabase ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: REQUIRED for admin writes. Never expose to client. Never prefix
# with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin credentials ────────────────────────────────
ADMIN_USER=admin@example.com

# Preferred: a bcrypt hash (cost ≥ 10).
# Generate with:
#   node -e "require('bcryptjs').hash(process.argv[1], 12).then(console.log)" 'your-strong-password'
ADMIN_PASSWORD_HASH=

# Legacy fallback (DEV ONLY — emits a console warning when used). Remove in
# production once ADMIN_PASSWORD_HASH is set.
ADMIN_PASSWORD=

# ── JWT signing secret ───────────────────────────────
# 32+ chars. Generate with: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-32-plus-character-random-string

# Optional: override session lifetime (seconds). Default 7200 (2 hours).
# Min 60, max 86400. Shorter is safer.
SESSION_MAX_AGE_SECONDS=

# ── Email (optional, Resend) ─────────────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL="Your Portfolio <onboarding@resend.dev>"

# ── Razorpay ─────────────────────────────────────────
# Key ID is public (loaded by checkout script).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# Secret is SERVER-ONLY — never prefix with NEXT_PUBLIC_.
RAZORPAY_KEY_SECRET=
